generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  spaces   Space[]
  sessions Session[]
}

model Session {
  id    String @id @default(cuid())
  userId String
  token String @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Space {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("My Workspace")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@unique([userId]) // One space per user
}

model Project {
  id          String   @id @default(cuid())
  spaceId     String
  name        String
  description String?
  subdomain   String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  space              Space               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  settings           ProjectSettings?
  gitConfig          GitConfig?
  githubToken        GithubToken?
}

model ProjectSettings {
  id        String   @id @default(cuid())
  projectId String   @unique
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model GitConfig {
  id                 String   @id @default(cuid())
  projectId          String   @unique
  prWorkflow         String?  // PR workflow configuration (JSON string)
  pushRepoUrl        String?  // Repository push URL
  pushBranch         String   @default("main")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model GithubToken {
  id          String   @id @default(cuid())
  projectId   String   @unique
  accessToken String
  scope       String?
  tokenType   String   @default("bearer")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AiKey {
  id        String   @id @default(cuid())
  provider  String   // "anthropic", "xai", etc.
  key       String   // Encrypted
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id                 String   @id @default(cuid())
  siteName           String   @default("Website Builder AI")
  primaryDomain      String   @default("builder.local")
  supportEmail       String   @default("support@example.com")
  maintenanceMode    Boolean  @default(false)
  maintenanceMessage String   @default("Site is under maintenance")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PricingPlan {
  id        String   @id @default(cuid())
  name      String   // "Free", "Pro", "Enterprise"
  price     Float
  currency  String   @default("USD")
  projects  Int      // Maximum projects
  storage   Int      // GB
  features  Json     @default("[]") // Array of features
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BillingRecord {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  currency    String  @default("USD")
  status      String  @default("pending") // "pending", "completed", "failed"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  secret    String   // Encrypted
  isActive  Boolean  @default(true)
  rateLimit Int      @default(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
